# Port configuration
PORT=3000

# MongoDB URI (MongoDB Atlas or Local MongoDB)
# Example: mongodb+srv://<username>:<password>@cluster.mongodb.net/quickfix
MONGODB_URI=your_mongodb_connection_string

# Secret key for JWT signing
JWT_SECRET=your_jwt_secret_key_here

# Firebase Adminsdk service account JSON filename (placed in quickfix_backend root)
FIREBASE_SERVICE_ACCOUNT_JSON=firebase-adminsdk.json

# Cloudinary Integration (for file uploads / image assets)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Administrator password for Admin Web Panel
ADMIN_PASSWORD=your_admin_dashboard_password
